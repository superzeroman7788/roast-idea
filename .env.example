# Server-side only. Never expose these in frontend code.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Kimi is Moonshot's OpenAI-compatible API.
KIMI_API_KEY=
MOONSHOT_API_KEY=
KIMI_MODEL=moonshot-v1-8k

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

QWEN_API_KEY=
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen-turbo

ROAST_API_PORT=8787

# ---- 用户体系(邮箱魔法链接 + 邀请制)----
# 会话签名密钥(生产务必设一个长随机串)
ROAST_JWT_SECRET=
# 站长邮箱:历史遗留讨论迁给它,且永远在邀请名单内
ROAST_OWNER_EMAIL=ln5423696@gmail.com
# 邀请白名单(逗号分隔);除站长外,只有这些邮箱能拿到登录链接
ROAST_ALLOWED_EMAILS=
# 魔法链接基址:不设则用请求 Host。本地开发用 vite 端口便于回跳:http://localhost:5173
ROAST_PUBLIC_URL=
# 发信(可选):配了就发真邮件,没配则把登录链接打到服务器日志(站长手动转发)
RESEND_API_KEY=
ROAST_MAIL_FROM=ROAST <onboarding@resend.dev>
